backups:
  # Raw database folder backups while DB stays running.
  # See docs/raw-db-folder-backup-guide.md before using this in production.
  - name: "mysql_data"
    type: folder
    source_path: "./data/mysql"
    storage: ["r2"]
    object_key_prefix: mysql
    remote_retention:
      enabled: true
      max_per_day: 3
      max_per_month: 1
      max_per_year: 1
    scheduler:
      enabled: true
      cron_expr: "0 2 * * *"
      max_backups: 3
    ignore:
      files: ["*.tmp", "*.pid", "*.sock", "mysql.sock"]
      folders: ["#innodb_temp", "tmp"]

  - name: "postgres_data"
    type: folder
    source_path: "./data/postgres"
    storage: ["r2"]
    object_key_prefix: postgres
    remote_retention:
      enabled: true
      max_per_day: 3
      max_per_month: 1
      max_per_year: 1
    scheduler:
      enabled: true
      cron_expr: "30 2 * * *"
      max_backups: 3
    ignore:
      files: ["*.pid", "*.tmp", "postmaster.pid", "postmaster.opts"]
      folders: ["pg_stat_tmp"]

  # Example: Backup folder
  - name: myfolder_backup
    type: folder
    source_path: /data/myfolder
    storage: [s3, google_drive]
    remote_retention:
      enabled: true
      max_per_day: 3
      max_per_month: 1
      max_per_year: 1
    scheduler:
      enabled: true
      cron_expr: "0 2 * * *"
      max_backups: 7
    ignore:
      files: ["*.log", "*.tmp"]
      folders: ["node_modules", ".git"]

  # Example: Backup MySQL database via SSH
  - name: mydb_backup
    type: mysql
    ssh:
      host: 1.2.3.4
      port: 22
      user: root
      key_file: /path/to/private_key
    db:
      name: mydb
      user: dbuser
      password: dbpass
      dump_options: ["--single-transaction", "--quick"]
    storage: [s3]
    scheduler:
      enabled: true
      cron_expr: "0 3 * * *"
      max_backups: 7
    ignore:
      files: []
      folders: []

  # Example: Backup PostgreSQL database via SSH
  - name: mypg_backup
    type: postgres
    ssh:
      host: 5.6.7.8
      port: 22
      user: postgres
      key_file: /path/to/private_key
    db:
      name: mypgdb
      user: pguser
      password: pgpass
      dump_options: ["--no-owner", "--no-acl"]
    storage: [google_drive]
    scheduler:
      enabled: false
      cron_expr: ""
      max_backups: 3
    ignore:
      files: []
      folders: []

  # Example: Backup multiple MySQL databases (each database will be a separate .sql file in the archive)
  - name: mysql-multi-db-backup
    type: mysql
    source_path: ./data/mysql-dumps
    storage: [s3, rsync]
    ssh:
      host: your-server.com
      port: 22
      user: your-username
      key_file: /path/to/your/private/key
    db:
      databases: ["db1", "db2", "db3"]
      # Or backup all databases (except system databases)
      # name: "__ALL__"
      # exclude_databases: ["information_schema", "performance_schema", "mysql", "sys"]
      user: mysql_user
      password: mysql_password
      dump_options: ["--single-transaction", "--routines", "--triggers"]
    scheduler:
      enabled: true
      cron_expr: "0 2 * * *"
      max_backups: 7

storage:
  # AWS S3
  s3:
    enabled: false
    kind: s3
    bucket: your-bucket
    region: ap-southeast-1
    access_key_id: your-access-key
    secret_access_key: your-secret-key

  # Local MinIO, see docs/s3-guide.md
  s3_local:
    enabled: false
    kind: s3
    bucket: backup-smoke
    region: us-east-1
    access_key_id: minioadmin
    secret_access_key: minioadmin
    endpoint: http://localhost:9000
    force_path_style: true

  # Cloudflare R2, see docs/s3-guide.md
  r2:
    enabled: false
    kind: s3
    bucket: your-r2-bucket-name
    region: auto
    access_key_id: your-r2-access-key-id
    secret_access_key: your-r2-secret-access-key
    endpoint: https://your-cloudflare-account-id.r2.cloudflarestorage.com
    force_path_style: true
    skip_bucket_validation: true
  rsync:
    enabled: false
    kind: rsync
    server: your-server.com
    username: your-username
    path: /path/to/backup
    port: 22
  # Service account mode: use with Google Workspace Shared Drive
  google_drive:
    enabled: true
    kind: google_drive
    auth_mode: service_account
    credentials_file: /path/to/service-account.json
    folder_id: your-google-drive-folder-id

  # OAuth user mode: use with personal My Drive
  google_drive_oauth:
    enabled: false
    kind: google_drive
    auth_mode: oauth_user
    client_secret_file: /path/to/oauth-client-secret.json
    token_file: /path/to/google-drive-token.json
    folder_id: your-google-drive-folder-id